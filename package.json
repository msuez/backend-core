    "redlock": "^5.0.0-beta.2"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/opossum": "^8.1.9",
    "express": "^4.21.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "zod": "^3.24.1"
  }
